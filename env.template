# AISquare Studio QA - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# STAGING ENVIRONMENT CONFIGURATION
# =============================================================================

# Your staging environment URLs
STAGING_LOGIN_URL=https://your-staging-domain.com/login
STAGING_URL=https://your-staging-domain.com

# Test credentials for staging environment
STAGING_EMAIL=test@example.com
STAGING_PASSWORD=your_test_password

# Alternative credentials for invalid login tests
INVALID_EMAIL=invalid@example.com
INVALID_PASSWORD=wrongpassword123

# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================

# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# BROWSER & TEST CONFIGURATION
# =============================================================================

# Set to false to see browser during tests (helpful for debugging)
HEADLESS_MODE=true

# Browser type (chromium, firefox, webkit)
BROWSER_TYPE=chromium

# Default timeout for page operations (milliseconds)
DEFAULT_TIMEOUT=30000

# Screenshot settings
CAPTURE_SCREENSHOTS=true
SCREENSHOT_ON_FAILURE=true
